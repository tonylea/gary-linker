{
  "name": "linker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "npm run lint:markdown && npm run lint:spelling && npm run lint:types && npm run lint:eslint",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint \"**/*.md\" --ignore node_modules --ignore dist --ignore playwright-report",
    "lint:spelling": "cspell README.md \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.config.{js,ts}\" \"scripts/**/*\"",
    "lint:types": "tsc -b --pretty false",
    "prepare": "husky",
    "test": "npm run test:vitest && npm run test:e2e",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "zsh scripts/service.sh deploy",
    "remove": "zsh scripts/service.sh remove"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.1.6",
    "vitest": "^4.1.7"
  }
}
